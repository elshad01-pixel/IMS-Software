generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum RiskStatus {
  OPEN
  IN_TREATMENT
  MITIGATED
  ACCEPTED
  CLOSED
}

enum CapaStatus {
  OPEN
  INVESTIGATING
  ACTION_PLANNED
  IN_PROGRESS
  VERIFIED
  CLOSED
}

enum DocumentStatus {
  DRAFT
  REVIEW
  APPROVED
  OBSOLETE
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum AuditFindingSeverity {
  OBSERVATION
  MINOR
  MAJOR
}

enum AuditFindingStatus {
  OPEN
  CAPA_CREATED
  CLOSED
}

enum AuditChecklistResponse {
  YES
  NO
  PARTIAL
}

enum ManagementReviewStatus {
  PLANNED
  HELD
  CLOSED
}

enum KpiDirection {
  AT_LEAST
  AT_MOST
}

enum TrainingAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

model Tenant {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  users             User[]
  roles             Role[]
  documents         Document[]
  risks             Risk[]
  capas             Capa[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  actionItems       ActionItem[]
  audits            Audit[]
  auditChecklistItems AuditChecklistItem[]
  auditFindings     AuditFinding[]
  managementReviews ManagementReview[]
  managementReviewInputs ManagementReviewInput[]
  kpis              Kpi[]
  kpiReadings       KpiReading[]
  trainings         Training[]
  trainingAssignments TrainingAssignment[]
  reports           ReportDefinition[]
  settings          TenantSetting[]
}

model User {
  id           String       @id @default(cuid())
  tenantId     String
  email        String
  firstName    String
  lastName     String
  passwordHash String
  isActive     Boolean      @default(true)
  roleId       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  auditLogs    AuditLog[]
  attachments  Attachment[]
  actionItems  ActionItem[] @relation("ActionItemOwner")

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id          String           @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType, entityId])
}

model Attachment {
  id           String   @id @default(cuid())
  tenantId     String
  uploadedById String?
  fileName     String
  objectKey    String   @unique
  mimeType     String
  size         Int
  sourceType   String
  sourceId     String
  createdAt    DateTime @default(now())
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenantId, sourceType, sourceId])
}

model ActionItem {
  id          String           @id @default(cuid())
  tenantId    String
  sourceType  String
  sourceId    String
  title       String
  description String?
  ownerId     String?
  dueDate     DateTime?
  status      ActionItemStatus @default(OPEN)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User?            @relation("ActionItemOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([tenantId, sourceType, sourceId])
}

model Document {
  id               String         @id @default(cuid())
  tenantId         String
  code             String
  title            String
  type             String
  summary          String?
  ownerId          String?
  version          Int            @default(1)
  revision         Int            @default(0)
  status           DocumentStatus @default(DRAFT)
  effectiveDate    DateTime?
  reviewDueDate    DateTime?
  approvedAt       DateTime?
  approvedById     String?
  obsoletedAt      DateTime?
  changeSummary    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
}

model Risk {
  id               String     @id @default(cuid())
  tenantId         String
  title            String
  description      String?
  category         String?
  likelihood       Int
  severity         Int
  score            Int
  treatmentPlan    String?
  treatmentSummary String?
  ownerId          String?
  targetDate       DateTime?
  status           RiskStatus @default(OPEN)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

model Capa {
  id                 String     @id @default(cuid())
  tenantId           String
  title              String
  source             String
  category           String?
  problemStatement   String
  containmentAction  String?
  rootCause          String?
  correction         String?
  correctiveAction   String?
  preventiveAction   String?
  verificationMethod String?
  closureSummary     String?
  ownerId            String?
  dueDate            DateTime?
  closedAt           DateTime?
  status             CapaStatus @default(OPEN)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  tenant             Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

model Audit {
  id              String              @id @default(cuid())
  tenantId        String
  code            String
  title           String
  type            String
  standard        String?
  scope           String?
  leadAuditorId   String?
  auditeeArea     String?
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  summary         String?
  status          AuditStatus         @default(PLANNED)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checklistItems  AuditChecklistItem[]
  findings        AuditFinding[]

  @@index([tenantId])
  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model ManagementReview {
  id            String                 @id @default(cuid())
  tenantId      String
  title         String
  reviewDate    DateTime?
  chairpersonId String?
  agenda        String?
  auditResults  String?
  capaStatus    String?
  kpiPerformance String?
  risksOpportunities String?
  changesAffectingSystem String?
  previousActions String?
  minutes       String?
  decisions     String?
  improvementActions String?
  resourceNeeds String?
  summary       String?
  status        ManagementReviewStatus @default(PLANNED)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inputs        ManagementReviewInput[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model Kpi {
  id               String       @id @default(cuid())
  tenantId         String
  name             String
  description      String?
  ownerId          String?
  target           Float
  warningThreshold Float?
  actual           Float
  unit             String
  periodLabel      String
  direction        KpiDirection @default(AT_LEAST)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  readings         KpiReading[]

  @@index([tenantId])
}

model Training {
  id             String               @id @default(cuid())
  tenantId       String
  title          String
  audience       String?
  description    String?
  ownerId        String?
  deliveryMethod String?
  dueDate        DateTime?
  completion     Float                @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments    TrainingAssignment[]

  @@index([tenantId])
}

model AuditChecklistItem {
  id         String   @id @default(cuid())
  tenantId   String
  auditId    String
  clause     String?
  standard   String?
  title      String
  notes      String?
  response   AuditChecklistResponse?
  isComplete Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  audit      Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([tenantId, auditId])
}

model AuditFinding {
  id           String              @id @default(cuid())
  tenantId     String
  auditId      String
  title        String
  description  String
  severity     AuditFindingSeverity
  ownerId      String?
  dueDate      DateTime?
  linkedCapaId String?
  status       AuditFindingStatus  @default(OPEN)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  audit        Audit               @relation(fields: [auditId], references: [id], onDelete: Cascade)

  @@index([tenantId, auditId])
  @@index([tenantId, status])
}

model ManagementReviewInput {
  id         String   @id @default(cuid())
  tenantId   String
  reviewId   String
  sourceType String
  sourceId   String
  title      String
  summary    String?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  review     ManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([tenantId, reviewId])
}

model KpiReading {
  id          String   @id @default(cuid())
  tenantId    String
  kpiId       String
  value       Float
  readingDate DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kpi         Kpi      @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([tenantId, kpiId])
}

model TrainingAssignment {
  id              String                   @id @default(cuid())
  tenantId        String
  trainingId      String
  userId          String
  dueDate         DateTime?
  completedAt     DateTime?
  status          TrainingAssignmentStatus @default(ASSIGNED)
  notes           String?
  evidenceSummary String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  training        Training                 @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@unique([trainingId, userId])
  @@index([tenantId, trainingId])
  @@index([tenantId, userId])
  @@index([tenantId, status])
}

model ReportDefinition {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  type        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantSetting {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}
