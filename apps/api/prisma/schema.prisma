generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActionItemStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELLED
}

enum RiskStatus {
  OPEN
  IN_TREATMENT
  MITIGATED
  ACCEPTED
  CLOSED
}

enum RiskIssueContextType {
  INTERNAL
  EXTERNAL
}

enum CapaStatus {
  OPEN
  INVESTIGATING
  ACTION_PLANNED
  IN_PROGRESS
  VERIFIED
  CLOSED
}

enum NcrCategory {
  PROCESS
  PRODUCT
  SERVICE
  SUPPLIER
  COMPLAINT
}

enum NcrSource {
  INTERNAL
  CUSTOMER
  SUPPLIER
  AUDIT
}

enum NcrStatus {
  OPEN
  UNDER_REVIEW
  INVESTIGATION
  ACTION_IN_PROGRESS
  PENDING_VERIFICATION
  CLOSED
  ARCHIVED
}

enum NcrSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NcrPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NcrVerificationStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum NcrRcaMethod {
  FIVE_WHY
  FISHBONE
  IS_IS_NOT
  OTHER
}

enum DocumentStatus {
  DRAFT
  REVIEW
  APPROVED
  OBSOLETE
}

enum AuditStatus {
  PLANNED
  IN_PROGRESS
  CHECKLIST_COMPLETED
  COMPLETED
  CLOSED
}

enum AuditFindingSeverity {
  OBSERVATION
  OPPORTUNITY
  MINOR
  MAJOR
}

enum AuditFindingStatus {
  OPEN
  CAPA_CREATED
  CLOSED
}

enum AuditChecklistResponse {
  YES
  NO
  PARTIAL
}

enum ManagementReviewStatus {
  PLANNED
  HELD
  CLOSED
}

enum KpiDirection {
  AT_LEAST
  AT_MOST
}

enum TrainingAssignmentStatus {
  ASSIGNED
  IN_PROGRESS
  COMPLETED
}

enum ProcessRegisterStatus {
  ACTIVE
  ARCHIVED
}

enum ProcessRegisterLinkType {
  DOCUMENT
  RISK
  AUDIT
  KPI
  ACTION
  NCR
  CONTEXT_ISSUE
}

enum ComplianceObligationStatus {
  ACTIVE
  UNDER_REVIEW
  OBSOLETE
}

enum ComplianceObligationLinkType {
  PROCESS
  RISK
  AUDIT
  ACTION
}

enum IncidentType {
  INCIDENT
  NEAR_MISS
}

enum IncidentCategory {
  SAFETY
  ENVIRONMENT
  QUALITY
  SECURITY
  OTHER
}

enum IncidentStatus {
  REPORTED
  INVESTIGATION
  ACTION_IN_PROGRESS
  CLOSED
  ARCHIVED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentLinkType {
  PROCESS
  RISK
  ACTION
}

enum IncidentRcaMethod {
  FIVE_WHY
  FISHBONE
  IS_IS_NOT
  OTHER
}

enum EnvironmentalAspectStage {
  NORMAL_OPERATION
  ABNORMAL_OPERATION
  EMERGENCY
}

enum EnvironmentalAspectSignificance {
  LOW
  MEDIUM
  HIGH
}

enum EnvironmentalAspectStatus {
  ACTIVE
  MONITORING
  OBSOLETE
}

enum EnvironmentalAspectLinkType {
  PROCESS
  RISK
  ACTION
}

enum HazardExposureStage {
  ROUTINE
  NON_ROUTINE
  EMERGENCY
}

enum HazardSeverity {
  LOW
  MEDIUM
  HIGH
}

enum HazardStatus {
  ACTIVE
  MONITORING
  OBSOLETE
}

enum HazardLinkType {
  PROCESS
  RISK
  ACTION
  INCIDENT
}

enum ExternalProviderType {
  SUPPLIER
  OUTSOURCED_SERVICE
  CONTRACTOR
  CALIBRATION
  LOGISTICS
  OTHER
}

enum ExternalProviderCriticality {
  LOW
  MEDIUM
  HIGH
}

enum ExternalProviderStatus {
  APPROVED
  CONDITIONAL
  UNDER_REVIEW
  INACTIVE
}

enum ExternalProviderEvaluationOutcome {
  APPROVED
  APPROVED_WITH_CONDITIONS
  ESCALATED
  DISQUALIFIED
}

enum ExternalProviderLinkType {
  PROCESS
  RISK
  AUDIT
  ACTION
  OBLIGATION
}

enum ChangeRequestType {
  PROCESS
  PRODUCT
  EQUIPMENT
  MATERIAL
  ORGANIZATIONAL
  DOCUMENTATION
  FACILITY
  OTHER
}

enum ChangeRequestStatus {
  PROPOSED
  REVIEWING
  APPROVED
  IMPLEMENTING
  VERIFIED
  CLOSED
  REJECTED
}

enum ChangeRequestLinkType {
  PROCESS
  RISK
  ACTION
  DOCUMENT
  OBLIGATION
  PROVIDER
}

enum RiskAssessmentType {
  RISK
  OPPORTUNITY
}

enum ContextIssueType {
  INTERNAL
  EXTERNAL
}

enum ContextIssueStatus {
  OPEN
  MONITORING
  RESOLVED
  ARCHIVED
}

enum InterestedPartyType {
  CUSTOMER
  REGULATOR
  EMPLOYEE
  SUPPLIER
  OTHER
}

enum CustomerSurveyRequestStatus {
  OPEN
  COMPLETED
  EXPIRED
  CANCELLED
}

model Tenant {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  users             User[]
  roles             Role[]
  documents         Document[]
  risks             Risk[]
  capas             Capa[]
  attachments       Attachment[]
  auditLogs         AuditLog[]
  actionItems       ActionItem[]
  audits            Audit[]
  auditChecklistQuestions AuditChecklistQuestion[]
  auditChecklistItems AuditChecklistItem[]
  auditFindings     AuditFinding[]
  managementReviews ManagementReview[]
  managementReviewInputs ManagementReviewInput[]
  kpis              Kpi[]
  kpiReadings       KpiReading[]
  trainings         Training[]
  trainingAssignments TrainingAssignment[]
  reports           ReportDefinition[]
  settings          TenantSetting[]
  ncrs              Ncr[]
  ncrComments       NcrComment[]
  processRegisters  ProcessRegister[]
  processRegisterLinks ProcessRegisterLink[]
  complianceObligations ComplianceObligation[]
  complianceObligationLinks ComplianceObligationLink[]
  incidents         Incident[]
  incidentLinks     IncidentLink[]
  environmentalAspects EnvironmentalAspect[]
  environmentalAspectLinks EnvironmentalAspectLink[]
  hazards          HazardIdentification[]
  hazardLinks      HazardIdentificationLink[]
  externalProviders ExternalProviderControl[]
  externalProviderLinks ExternalProviderLink[]
  changeRequests    ChangeRequest[]
  changeRequestLinks ChangeRequestLink[]
  contextIssues     ContextIssue[]
  interestedParties InterestedParty[]
  needExpectations  NeedExpectation[]
  customerSurveyRequests CustomerSurveyRequest[]
  contextIssueRiskLinks ContextIssueRiskLink[]
}

model User {
  id           String       @id @default(cuid())
  tenantId     String
  email        String
  firstName    String
  lastName     String
  passwordHash String
  isActive     Boolean      @default(true)
  roleId       String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         Role?        @relation(fields: [roleId], references: [id], onDelete: SetNull)
  auditLogs    AuditLog[]
  attachments  Attachment[]
  actionItems  ActionItem[] @relation("ActionItemOwner")
  ncrComments  NcrComment[] @relation("NcrCommentAuthor")
  ownedProcesses ProcessRegister[] @relation("ProcessOwner")
  deletedProcesses ProcessRegister[] @relation("ProcessDeletedBy")
  createdProcessLinks ProcessRegisterLink[] @relation("ProcessLinkCreator")

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id          String           @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  roles       RolePermission[]
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  actorId    String?
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType, entityId])
}

model Attachment {
  id           String   @id @default(cuid())
  tenantId     String
  uploadedById String?
  deletedById  String?
  fileName     String
  objectKey    String   @unique
  mimeType     String
  size         Int
  sourceType   String
  sourceId     String
  createdAt    DateTime @default(now())
  deletedAt    DateTime?
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([tenantId, sourceType, sourceId])
}

model ActionItem {
  id          String           @id @default(cuid())
  tenantId    String
  deletedById String?
  sourceType  String
  sourceId    String
  title       String
  description String?
  ownerId     String?
  dueDate     DateTime?
  status      ActionItemStatus @default(OPEN)
  createdAt   DateTime         @default(now())
  deletedAt   DateTime?
  updatedAt   DateTime         @updatedAt
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User?            @relation("ActionItemOwner", fields: [ownerId], references: [id], onDelete: SetNull)

  @@index([tenantId, sourceType, sourceId])
}

model Document {
  id               String         @id @default(cuid())
  tenantId         String
  deletedById      String?
  code             String
  title            String
  type             String
  summary          String?
  ownerId          String?
  version          Int            @default(1)
  revision         Int            @default(0)
  status           DocumentStatus @default(DRAFT)
  effectiveDate    DateTime?
  reviewDueDate    DateTime?
  approvedAt       DateTime?
  approvedById     String?
  obsoletedAt      DateTime?
  deletedAt        DateTime?
  changeSummary    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
}

model Risk {
  id               String     @id @default(cuid())
  tenantId         String
  deletedById      String?
  assessmentType   RiskAssessmentType @default(RISK)
  title            String
  description      String?
  category         String?
  likelihood       Int
  severity         Int
  score            Int
  existingControls String?
  plannedMitigationActions String?
  residualLikelihood Int?
  residualImpact   Int?
  residualScore    Int?
  issueContextType RiskIssueContextType?
  issueContext     String?
  treatmentPlan    String?
  treatmentSummary String?
  ownerId          String?
  targetDate       DateTime?
  status           RiskStatus @default(OPEN)
  createdAt        DateTime   @default(now())
  deletedAt        DateTime?
  updatedAt        DateTime   @updatedAt
  tenant           Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

model Capa {
  id                 String     @id @default(cuid())
  tenantId           String
  deletedById        String?
  title              String
  source             String
  category           String?
  problemStatement   String
  containmentAction  String?
  rootCause          String?
  correction         String?
  correctiveAction   String?
  preventiveAction   String?
  verificationMethod String?
  closureSummary     String?
  ownerId            String?
  dueDate            DateTime?
  closedAt           DateTime?
  deletedAt          DateTime?
  status             CapaStatus @default(OPEN)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  tenant             Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([tenantId, status])
}

model Ncr {
  id                      String                @id @default(cuid())
  tenantId                String
  deletedById             String?
  referenceNo             String
  title                   String
  category                NcrCategory
  source                  NcrSource
  description             String
  status                  NcrStatus             @default(OPEN)
  severity                NcrSeverity
  priority                NcrPriority
  dateReported            DateTime
  reportedByUserId        String?
  ownerUserId             String?
  department              String?
  location                String?
  dueDate                 DateTime?
  containmentAction       String?
  investigationSummary    String?
  rootCause               String?
  rcaMethod               NcrRcaMethod?
  correctiveActionSummary String?
  verificationStatus      NcrVerificationStatus @default(PENDING)
  verifiedByUserId        String?
  verificationDate        DateTime?
  deletedAt               DateTime?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  tenant                  Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  comments                NcrComment[]

  @@unique([tenantId, referenceNo])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, dueDate])
}

model NcrComment {
  id        String   @id @default(cuid())
  tenantId  String
  ncrId     String
  authorId  String
  message   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ncr       Ncr      @relation(fields: [ncrId], references: [id], onDelete: Cascade)
  author    User     @relation("NcrCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId, ncrId, createdAt])
}

model ProcessRegister {
  id          String                @id @default(cuid())
  tenantId    String
  referenceNo String?
  name        String
  purpose     String?
  ownerUserId String?
  department  String?
  scope       String?
  inputsText  String?
  outputsText String?
  status      ProcessRegisterStatus @default(ACTIVE)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  deletedAt   DateTime?
  deletedById String?
  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  owner       User?                 @relation("ProcessOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  deletedBy   User?                 @relation("ProcessDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  links       ProcessRegisterLink[]

  @@unique([tenantId, referenceNo])
  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, deletedAt])
}

model ProcessRegisterLink {
  id          String                  @id @default(cuid())
  tenantId    String
  processId   String
  linkType    ProcessRegisterLinkType
  linkedId    String
  note        String?
  createdAt   DateTime                @default(now())
  createdById String?
  tenant      Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  process     ProcessRegister         @relation(fields: [processId], references: [id], onDelete: Cascade)
  createdBy   User?                   @relation("ProcessLinkCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([processId, linkType, linkedId])
  @@index([tenantId, processId])
  @@index([tenantId, linkType, linkedId])
}

model ComplianceObligation {
  id                    String                     @id @default(cuid())
  tenantId              String
  referenceNo           String?
  title                 String
  sourceName            String
  obligationType        String?
  jurisdiction          String?
  description           String?
  ownerUserId           String?
  reviewFrequencyMonths Int?
  nextReviewDate        DateTime?
  status                ComplianceObligationStatus @default(ACTIVE)
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  deletedAt             DateTime?
  deletedById           String?
  tenant                Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  links                 ComplianceObligationLink[]

  @@unique([tenantId, referenceNo])
  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, nextReviewDate])
  @@index([tenantId, deletedAt])
}

model ComplianceObligationLink {
  id           String                       @id @default(cuid())
  tenantId     String
  obligationId String
  linkType     ComplianceObligationLinkType
  linkedId     String
  note         String?
  createdAt    DateTime                     @default(now())
  createdById  String?
  tenant       Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  obligation   ComplianceObligation         @relation(fields: [obligationId], references: [id], onDelete: Cascade)

  @@unique([obligationId, linkType, linkedId])
  @@index([tenantId, obligationId])
  @@index([tenantId, linkType, linkedId])
}

model Incident {
  id                      String           @id @default(cuid())
  tenantId                String
  referenceNo             String?
  title                   String
  type                    IncidentType
  category                IncidentCategory
  description             String
  eventDate               DateTime
  location                String?
  ownerUserId             String?
  severity                IncidentSeverity
  immediateAction         String?
  investigationSummary    String?
  rootCause               String?
  rcaMethod               IncidentRcaMethod?
  correctiveActionSummary String?
  status                  IncidentStatus   @default(REPORTED)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  deletedAt               DateTime?
  deletedById             String?
  tenant                  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  links                   IncidentLink[]

  @@unique([tenantId, referenceNo])
  @@index([tenantId, status])
  @@index([tenantId, type])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, eventDate])
  @@index([tenantId, deletedAt])
}

model IncidentLink {
  id         String           @id @default(cuid())
  tenantId   String
  incidentId String
  linkType   IncidentLinkType
  linkedId   String
  note       String?
  createdAt  DateTime         @default(now())
  createdById String?
  tenant     Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  incident   Incident         @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@unique([incidentId, linkType, linkedId])
  @@index([tenantId, incidentId])
  @@index([tenantId, linkType, linkedId])
}

model EnvironmentalAspect {
  id             String                           @id @default(cuid())
  tenantId       String
  referenceNo    String?
  activity       String
  aspect         String
  impact         String
  lifecycleStage EnvironmentalAspectStage
  controlSummary String?
  significance   EnvironmentalAspectSignificance
  ownerUserId    String?
  reviewDate     DateTime?
  status         EnvironmentalAspectStatus       @default(ACTIVE)
  createdAt      DateTime                         @default(now())
  updatedAt      DateTime                         @updatedAt
  deletedAt      DateTime?
  deletedById    String?
  tenant         Tenant                           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  links          EnvironmentalAspectLink[]

  @@unique([tenantId, referenceNo])
  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, reviewDate])
  @@index([tenantId, deletedAt])
}

model EnvironmentalAspectLink {
  id          String                       @id @default(cuid())
  tenantId    String
  aspectId    String
  linkType    EnvironmentalAspectLinkType
  linkedId    String
  note        String?
  createdAt   DateTime                     @default(now())
  createdById String?
  tenant      Tenant                       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  aspect      EnvironmentalAspect          @relation(fields: [aspectId], references: [id], onDelete: Cascade)

  @@unique([aspectId, linkType, linkedId])
  @@index([tenantId, aspectId])
  @@index([tenantId, linkType, linkedId])
}

model HazardIdentification {
  id             String              @id @default(cuid())
  tenantId       String
  referenceNo    String?
  activity       String
  hazard         String
  potentialHarm  String
  exposureStage  HazardExposureStage
  existingControls String?
  severity       HazardSeverity
  ownerUserId    String?
  reviewDate     DateTime?
  status         HazardStatus        @default(ACTIVE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  deletedAt      DateTime?
  deletedById    String?
  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  links          HazardIdentificationLink[]

  @@unique([tenantId, referenceNo])
  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, reviewDate])
  @@index([tenantId, deletedAt])
}

model HazardIdentificationLink {
  id          String          @id @default(cuid())
  tenantId    String
  hazardId    String
  linkType    HazardLinkType
  linkedId    String
  note        String?
  createdAt   DateTime        @default(now())
  createdById String?
  tenant      Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hazard      HazardIdentification @relation(fields: [hazardId], references: [id], onDelete: Cascade)

  @@unique([hazardId, linkType, linkedId])
  @@index([tenantId, hazardId])
  @@index([tenantId, linkType, linkedId])
}

model ExternalProviderControl {
  id               String                    @id @default(cuid())
  tenantId         String
  referenceNo      String?
  providerName     String
  providerType     ExternalProviderType
  suppliedScope    String
  approvalBasis    String?
  criticality      ExternalProviderCriticality
  ownerUserId      String?
  evaluationDate   DateTime?
  qualityScore     Int?
  deliveryScore    Int?
  responsivenessScore Int?
  complianceScore  Int?
  traceabilityScore Int?
  changeControlScore Int?
  evaluationScore  Int?
  evaluationOutcome ExternalProviderEvaluationOutcome?
  evaluationSummary String?
  nextReviewDate   DateTime?
  status           ExternalProviderStatus    @default(APPROVED)
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  deletedAt        DateTime?
  deletedById      String?
  tenant           Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  links            ExternalProviderLink[]

  @@unique([tenantId, referenceNo])
  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, nextReviewDate])
  @@index([tenantId, deletedAt])
}

model ExternalProviderLink {
  id               String                 @id @default(cuid())
  tenantId         String
  providerId       String
  linkType         ExternalProviderLinkType
  linkedId         String
  note             String?
  createdAt        DateTime               @default(now())
  createdById      String?
  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider         ExternalProviderControl @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@unique([providerId, linkType, linkedId])
  @@index([tenantId, providerId])
  @@index([tenantId, linkType, linkedId])
}

model ChangeRequest {
  id                       String              @id @default(cuid())
  tenantId                 String
  referenceNo              String?
  title                    String
  changeType               ChangeRequestType
  reason                   String
  affectedArea             String
  proposedChange           String
  impactSummary            String?
  controlSummary           String?
  ownerUserId              String?
  targetImplementationDate DateTime?
  reviewDate               DateTime?
  status                   ChangeRequestStatus @default(PROPOSED)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  deletedAt                DateTime?
  deletedById              String?
  tenant                   Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  links                    ChangeRequestLink[]

  @@unique([tenantId, referenceNo])
  @@index([tenantId, status])
  @@index([tenantId, ownerUserId])
  @@index([tenantId, targetImplementationDate])
  @@index([tenantId, deletedAt])
}

model ChangeRequestLink {
  id          String                @id @default(cuid())
  tenantId    String
  changeId    String
  linkType    ChangeRequestLinkType
  linkedId    String
  note        String?
  createdAt   DateTime              @default(now())
  createdById String?
  tenant      Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  change      ChangeRequest         @relation(fields: [changeId], references: [id], onDelete: Cascade)

  @@unique([changeId, linkType, linkedId])
  @@index([tenantId, changeId])
  @@index([tenantId, linkType, linkedId])
}

model ContextIssue {
  id          String             @id @default(cuid())
  tenantId    String
  type        ContextIssueType
  title       String
  description String
  impactOnBusiness String?
  category    String?
  status      ContextIssueStatus @default(OPEN)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  riskLinks   ContextIssueRiskLink[]

  @@index([tenantId, type, status])
  @@index([tenantId, deletedAt])
}

model InterestedParty {
  id          String              @id @default(cuid())
  tenantId    String
  name        String
  type        InterestedPartyType
  description String?
  surveyEnabled Boolean           @default(false)
  surveyTitle String?
  surveyIntro String?
  surveyScaleMax Int?
  surveyCategoryLabels Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  deletedAt   DateTime?
  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  needs       NeedExpectation[]
  surveyRequests CustomerSurveyRequest[]

  @@index([tenantId, type])
  @@index([tenantId, deletedAt])
}

model CustomerSurveyRequest {
  id                  String                      @id @default(cuid())
  tenantId            String
  interestedPartyId   String
  token               String                      @unique
  title               String
  intro               String?
  scaleMax            Int
  categoryLabels      Json
  recipientName       String?
  recipientEmail      String?
  status              CustomerSurveyRequestStatus @default(OPEN)
  sentAt              DateTime?
  expiresAt           DateTime?
  completedAt         DateTime?
  respondentName      String?
  respondentEmail     String?
  respondentCompany   String?
  respondentReference String?
  ratings             Json?
  whatWorkedWell      String?
  improvementPriority String?
  comments            String?
  averageScore        Float?
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt
  tenant              Tenant                      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  interestedParty     InterestedParty             @relation(fields: [interestedPartyId], references: [id], onDelete: Cascade)

  @@index([tenantId, interestedPartyId])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model NeedExpectation {
  id                String           @id @default(cuid())
  tenantId          String
  interestedPartyId String
  description       String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  deletedAt         DateTime?
  tenant            Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  interestedParty   InterestedParty  @relation(fields: [interestedPartyId], references: [id], onDelete: Cascade)

  @@index([tenantId, interestedPartyId])
  @@index([tenantId, deletedAt])
}

model ContextIssueRiskLink {
  id          String   @id @default(cuid())
  tenantId    String
  issueId     String
  riskId      String
  createdAt   DateTime @default(now())
  createdById String?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  issue       ContextIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)

  @@unique([issueId, riskId])
  @@index([tenantId, issueId])
  @@index([tenantId, riskId])
}

model Audit {
  id              String              @id @default(cuid())
  tenantId        String
  deletedById     String?
  code            String
  title           String
  type            String
  standard        String?
  programme       String?
  scopeType       String?
  scope           String?
  objectives      String?
  criteria        String?
  agenda          String?
  openingMeetingNotes String?
  closingMeetingNotes String?
  leadAuditorId   String?
  auditeeArea     String?
  scheduledAt     DateTime?
  startedAt       DateTime?
  checklistCompletedAt DateTime?
  completedAt     DateTime?
  completedByAuditorId String?
  summary         String?
  conclusion      String?
  recommendations String?
  status          AuditStatus         @default(PLANNED)
  createdAt       DateTime            @default(now())
  deletedAt       DateTime?
  updatedAt       DateTime            @updatedAt
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checklistItems  AuditChecklistItem[]
  findings        AuditFinding[]

  @@index([tenantId])
  @@unique([tenantId, code])
  @@index([tenantId, status])
}

model ManagementReview {
  id            String                 @id @default(cuid())
  tenantId      String
  deletedById   String?
  title         String
  reviewDate    DateTime?
  chairpersonId String?
  agenda        String?
  auditResults  String?
  capaStatus    String?
  kpiPerformance String?
  customerInterestedPartiesFeedback String?
  providerPerformance String?
  complianceObligations String?
  incidentEmergencyPerformance String?
  consultationCommunication String?
  risksOpportunities String?
  changesAffectingSystem String?
  previousActions String?
  minutes       String?
  decisions     String?
  improvementActions String?
  systemChangesNeeded String?
  objectiveTargetChanges String?
  resourceNeeds String?
  effectivenessConclusion String?
  summary       String?
  status        ManagementReviewStatus @default(PLANNED)
  createdAt     DateTime               @default(now())
  deletedAt     DateTime?
  updatedAt     DateTime               @updatedAt
  tenant        Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inputs        ManagementReviewInput[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model Kpi {
  id               String       @id @default(cuid())
  tenantId         String
  name             String
  description      String?
  ownerId          String?
  target           Float
  warningThreshold Float?
  actual           Float
  unit             String
  periodLabel      String
  direction        KpiDirection @default(AT_LEAST)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  readings         KpiReading[]

  @@index([tenantId])
}

model Training {
  id             String               @id @default(cuid())
  tenantId       String
  title          String
  audience       String?
  description    String?
  ownerId        String?
  deliveryMethod String?
  dueDate        DateTime?
  completion     Float                @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assignments    TrainingAssignment[]

  @@index([tenantId])
}

model AuditChecklistItem {
    id         String   @id @default(cuid())
    tenantId   String
    auditId    String
    sourceQuestionId String?
    clause     String?
    subclause  String?
    standard   String?
    title      String
    notes      String?
    response   AuditChecklistResponse?
    isComplete Boolean  @default(false)
  sortOrder  Int      @default(0)
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
    tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
    audit      Audit    @relation(fields: [auditId], references: [id], onDelete: Cascade)
    sourceQuestion AuditChecklistQuestion? @relation(fields: [sourceQuestionId], references: [id], onDelete: SetNull)
    findings   AuditFinding[]

    @@index([tenantId, auditId])
    @@index([tenantId, sourceQuestionId])
  }

model AuditChecklistQuestion {
  id                String   @id @default(cuid())
  tenantId          String
  standard          String
  clause            String
  subclause         String?
  title             String
  sortOrder         Int      @default(0)
  isActive          Boolean  @default(true)
  isTemplateDefault Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  checklistItems    AuditChecklistItem[]

  @@index([tenantId, standard, clause, sortOrder])
  @@index([tenantId, isActive])
}

model AuditFinding {
  id           String              @id @default(cuid())
  tenantId     String
  auditId      String
  checklistItemId String?
  clause       String?
  title        String
  description  String
  severity     AuditFindingSeverity
  ownerId      String?
  dueDate      DateTime?
  linkedCapaId String?
  linkedActionItemId String?
  status       AuditFindingStatus  @default(OPEN)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  audit        Audit               @relation(fields: [auditId], references: [id], onDelete: Cascade)
  checklistItem AuditChecklistItem? @relation(fields: [checklistItemId], references: [id], onDelete: SetNull)

  @@index([tenantId, auditId])
  @@index([tenantId, checklistItemId])
  @@index([tenantId, status])
}

model ManagementReviewInput {
  id         String   @id @default(cuid())
  tenantId   String
  reviewId   String
  sourceType String
  sourceId   String
  title      String
  summary    String?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  review     ManagementReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([tenantId, reviewId])
}

model KpiReading {
  id          String   @id @default(cuid())
  tenantId    String
  kpiId       String
  value       Float
  readingDate DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kpi         Kpi      @relation(fields: [kpiId], references: [id], onDelete: Cascade)

  @@index([tenantId, kpiId])
}

model TrainingAssignment {
  id              String                   @id @default(cuid())
  tenantId        String
  trainingId      String
  userId          String
  dueDate         DateTime?
  completedAt     DateTime?
  status          TrainingAssignmentStatus @default(ASSIGNED)
  notes           String?
  evidenceSummary String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  training        Training                 @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  @@unique([trainingId, userId])
  @@index([tenantId, trainingId])
  @@index([tenantId, userId])
  @@index([tenantId, status])
}

model ReportDefinition {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  type        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model TenantSetting {
  id        String   @id @default(cuid())
  tenantId  String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId])
}
